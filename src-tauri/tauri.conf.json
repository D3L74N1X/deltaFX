{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "deltaFX",
  "version": "0.1.0",
  "identifier": "app.deltafx.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "deltaFX – Control Panel",
        "url": "index.html",
        "width": 1100,
        "height": 740,
        "minWidth": 860,
        "minHeight": 560
      },
      {
        "label": "overlay",
        "title": "deltaFX – Overlay",
        "url": "overlay.html",
        "width": 1280,
        "height": 720,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "resizable": true,
        "skipTaskbar": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/assets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
